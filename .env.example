# ══════════════════════════════════════════════════════════════
#  EconRadar — Exemplo de variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  Este arquivo É versionado no Git (sem valores sensíveis).
#  O .env de verdade NUNCA deve ir para o Git (já está no .gitignore).
# ══════════════════════════════════════════════════════════════

# ── Banco de dados (PostgreSQL) ───────────────────────────────────────────────
# Use um usuário de aplicação que seja DONO do banco 'econradar' (não o
# superusuário 'postgres'), e nunca deixe DB_PASSWORD vazio — o servidor
# recusa subir sem ele. Veja DATABASE_SETUP.md para criar isso em 2 comandos.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=econradar_app
DB_PASSWORD=
DB_NAME=econradar

# ── Segurança ──────────────────────────────────────────────────────────────────
# JWT: gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Criptografia de dados sensíveis (chaves de API, posições B3): gere com
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ATENÇÃO: se você perder esta chave, os dados cifrados no banco ficam
# irrecuperáveis. Guarde-a num cofre de segredos, não só no .env local.
ENCRYPTION_KEY=

# Duração dos tokens
ACCESS_TOKEN_MIN=30
REFRESH_TOKEN_DAYS=30

# ── Chaves de API padrão do servidor (opcional) ───────────────────────────────
# Se preenchidas, valem para todo mundo por padrão. Cada usuário também pode
# cadastrar a própria chave em /api/users/apikeys (fica cifrada no banco).
OPENROUTER_API_KEY=sk-or-v1-
FINNHUB_API_KEY=

# ── Configurações opcionais ────────────────────────────────────────────────────
OR_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
ALLOWED_ORIGINS=
